
%macro SERIAL_WRITE_WORD source
    $UART = 127
    LD %source
    MOV RAM->A

    LD $UART_TX
    mov a ram

%end_macro

%macro LOAD_REG constant register
    LD %constant
    MOV RAM %register
%end_macro

%macro LOAD_MEMORY source target

    LOAD_REG %source A
    LD %target
    MOV A RAM

%end_macro

%macro MUL src1 src2 dest
    MOV zero B
    LOAD_REG %src1 A
    LOAD_REG %src2 X
    MULADD
    LD %dest
    MOV res ram
%end_macro